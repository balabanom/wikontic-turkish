# --- Mongo ---
MONGO_URI=mongodb://localhost:27018/?directConnection=true

# --- OpenRouter (OpenAI-compatible) ---
# OpenRouter endpoint:
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

OPENAI_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter API key (get yours at https://openrouter.ai/keys)
KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: HTTP proxy URL (leave empty if not needed)
PROXY_URL=

# Optional: used by the Streamlit "Extract (without DB)" button
WIKONTIC_API_URL=http://localhost:8000

LLM_LOG_LEVEL=full   # full = tüm mesajlar, preview = ilk 200 char
LLM_LOG_PATH=logs/llm_requests.jsonl
